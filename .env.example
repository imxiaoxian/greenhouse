# ===== DeepSeek API =====
# 申请地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ===== OpenWeatherMap API =====
# 申请地址：https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-api-key

# ===== MCP 服务配置 =====
# 天气 MCP 服务的传输方式：stdio 或 sse
WEATHER_MCP_TRANSPORT=stdio

# SSE 模式时的监听地址（仅当 WEATHER_MCP_TRANSPORT=sse 时生效）
WEATHER_MCP_HOST=127.0.0.1
WEATHER_MCP_PORT=8765

# ===== 病虫害知识库配置 =====
# 后端选择：sqlite（轻量级，默认）或 postgres（企业级）
KNOWLEDGE_DB_BACKEND=sqlite

# SQLite 模式（默认）
# 数据文件位于 data/pest_disease.db

# PostgreSQL 模式（企业级部署时启用）
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_DATABASE=greenhouse
# PG_USER=postgres
# PG_PASSWORD=your_password

# 语义搜索参数
# 相似度阈值（0-1，低于此值则触发 DeepSeek 兜底）
SIMILARITY_THRESHOLD=0.65
# BGE Embedding 模型名称
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# HuggingFace 镜像（国内网络无法访问 huggingface.co 时启用）
HF_ENDPOINT=https://hf-mirror.com
# 禁用 Xet 协议下载（镜像不支持，回退到传统 HTTP）
HF_HUB_DISABLE_XET=1
